# ===========================================
# 日本クラリネット協会 公式サイト
# 環境変数サンプル（.env.local のテンプレート）
# ===========================================
# 本ファイルをコピーして .env.local を作成し、値を設定してください。
# 別のPCで OneDrive のフォルダを開いて開発する場合も、そのPCで .env.local を用意してください（README の「別のPCで開発する場合」を参照）。
# Vercel にデプロイする場合は、Vercel ダッシュボードで環境変数を設定してください。

# Supabase（データベース・認証）
# Supabase ダッシュボード > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Supabase 管理用（事務局ダッシュボード用・サーバーサイドのみ）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe（決済）
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# サイトURL（本番・プレビューで使用。未設定時は Vercel のホスト・localhost にフォールバック）
# メール内の振込証明アップロードURLのドメインにも使う。次の形式のみ（末尾パスは付けない）:
#   https://実際にサイトが表示されるドメイン
# 本番: https://japan-clarinet-association.jp （Vercel の Production 環境変数で必ず設定推奨）
# NEXT_PUBLIC_SITE_URL=https://japan-clarinet-association.jp

# メール送信（Gmail）
# アプリパスワード：Google アカウントで2段階認証を有効にした後、
# https://myaccount.google.com/apppasswords で生成（16文字）
EMAIL_USER=your-gmail@gmail.com
EMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# 送信元表示（Gmail 認証アカウントと異なる From にする場合は必須に近い）
# EMAIL_FROM=日本クラリネット協会 <your-gmail@gmail.com>
# 事務局への通知メール宛先（コンクール決済完了・入会完了など）。省略時は EMAIL_USER
# OFFICE_NOTIFY_EMAIL=jca@jp-clarinet.org
